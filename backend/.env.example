# Copiar a .env y ajustar valores. No commitear .env.

PORT=3000
CORS_ORIGIN=http://localhost:4200

# JWT (se usará en el apartado 03 — Auth)
# En NODE_ENV=production es obligatorio y no puede ser un placeholder.
JWT_SECRET=cambia-este-secreto-en-local
JWT_EXPIRES_IN=7d

# Base de datos
# Local (npm): SQLite
DATABASE_URL="file:./dev.db"
# Docker Compose (Postgres): se inyecta en el servicio `api`
# DATABASE_URL="postgresql://cinebook:cinebook@localhost:5432/cinebook"
