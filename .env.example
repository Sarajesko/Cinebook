# Copiar a .env en la raíz del monorepo para Docker Compose.
# No commitear .env (solo este ejemplo).

# Postgres
POSTGRES_USER=cinebook
POSTGRES_PASSWORD=cinebook
POSTGRES_DB=cinebook
POSTGRES_PORT=5433

# API (usa 3001 si 3000 ya está ocupado en el host)
# JWT_SECRET es obligatorio con Compose (NODE_ENV=production); usa un valor único fuerte.
API_PORT=3000
JWT_SECRET=pon-aqui-un-secreto-largo-y-unico
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:4200
